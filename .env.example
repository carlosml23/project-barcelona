# Copy this file to .env and fill in values.
# Do not commit .env.

# Required: External search API keys
EXA_API=
TAVILY_API=
FIRECRAWL=

# Required for synthesis, refinement, and discovery (optional — heuristic fallback if absent)
ANTHROPIC_API_KEY=

# SQLite database path (default: ./data/app.db)
# SQLITE_PATH=./data/app.db

# Logging level (default: info)
# LOG_LEVEL=info

# Refiner configuration (agentic refinement loop)
# REFINER_MAX_ITERATIONS=3
# REFINER_MAX_TOOL_CALLS=6

# Discovery configuration (agentic discovery via Claude web_search/web_fetch)
# DISCOVERY_ENABLED=true          # Set to false to disable agentic discovery
# DISCOVERY_MAX_SEARCHES=5        # Max web_search calls per case (cost: $0.01/search)
# DISCOVERY_MAX_FETCHES=3         # Max web_fetch calls per case (FREE)
